{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@relay-mvp/sdk": ["../../packages/sdk/src/index.ts"],
      "@relay-mvp/ui": ["../../packages/ui/src/index.ts"],
      "@relay-mvp/protocol": ["../../packages/protocol/src/index.ts"]
    }
  },
  "include": ["src", "src/vite-env.d.ts"]
}
